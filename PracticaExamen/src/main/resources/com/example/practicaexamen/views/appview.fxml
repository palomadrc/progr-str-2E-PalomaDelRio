<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.practicaexamen.controllers.AppControllers">
   <children>
      <Label text="CONTACTOS DE EMERGENCIA" />
      <VBox prefHeight="123.0" prefWidth="600.0">
         <children>
            <GridPane>
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <ComboBox fx:id="cdParentescos" prefWidth="150.0" promptText="-Seleccione uno" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="Telefono" GridPane.rowIndex="1" />
                  <Label text="Nombre" />
                  <TextField fx:id="txtName" GridPane.columnIndex="1" />
                  <TextField fx:id="txtTel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Parentesco" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox prefHeight="49.0" prefWidth="600.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onAddContact" text="Agregar" />
                  <Button mnemonicParsing="false" onAction="#onUpdate" text="Actualizar" />
                  <Button mnemonicParsing="false" onAction="#onDelete" text="Eliminar" />
                  <Button mnemonicParsing="false" onAction="#onSearch" text="Buscar" />
                  <Button mnemonicParsing="false" onAction="#onClear" text="Limpiar" />
               </children>
            </HBox>
         </children>
      </VBox>
      <ListView fx:id="listViewContacts" editable="true" prefHeight="111.0" prefWidth="600.0" />
      <Label text="Label" />
   </children>
</VBox>
